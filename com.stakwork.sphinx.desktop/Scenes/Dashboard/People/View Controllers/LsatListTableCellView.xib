<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.Cocoa.XIB" version="3.0" toolsVersion="21507" targetRuntime="MacOSX.Cocoa" propertyAccessControl="none" useAutolayout="YES" customObjectInstantitationMethod="direct">
    <dependencies>
        <deployment identifier="macosx"/>
        <plugIn identifier="com.apple.InterfaceBuilder.CocoaPlugin" version="21507"/>
        <capability name="Named colors" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <customObject id="-2" userLabel="File's Owner" customClass="LsatListTableCellView" customModule="Sphinx" customModuleProvider="target"/>
        <customObject id="-1" userLabel="First Responder" customClass="FirstResponder"/>
        <customObject id="-3" userLabel="Application" customClass="NSObject"/>
        <tableCellView identifier="LsatListTableCellView" id="eMx-Yg-Cou" customClass="LsatListTableCellView" customModule="Sphinx" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="480" height="120"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- tokenLabel: macaroon text, bold, truncates tail -->
                <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" horizontalCompressionResistancePriority="250" translatesAutoresizingMaskIntoConstraints="NO" id="tok-L1-abc">
                    <rect key="frame" x="16" y="80" width="300" height="20"/>
                    <textFieldCell key="cell" lineBreakMode="truncatingTail" sendsActionOnEndEditing="YES" title="macaroon" id="tok-c-abc">
                        <font key="font" metaFont="systemBold"/>
                        <color key="textColor" name="BodyInverted"/>
                        <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                    </textFieldCell>
                </textField>
                <!-- issuerLabel: issuer secondary text -->
                <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" horizontalCompressionResistancePriority="250" translatesAutoresizingMaskIntoConstraints="NO" id="iss-L2-def">
                    <rect key="frame" x="16" y="56" width="300" height="17"/>
                    <textFieldCell key="cell" lineBreakMode="truncatingTail" sendsActionOnEndEditing="YES" title="issuer" id="iss-c-def">
                        <font key="font" usesAppearanceFont="YES"/>
                        <color key="textColor" name="SecondaryText"/>
                        <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                    </textFieldCell>
                </textField>
                <!-- activePillBox: green pill -->
                <box boxType="custom" borderType="none" cornerRadius="10" translatesAutoresizingMaskIntoConstraints="NO" id="pill-B1-ghi">
                    <rect key="frame" x="16" y="24" width="64" height="20"/>
                    <view key="contentView" id="pill-cv-ghi">
                        <rect key="frame" x="0.0" y="0.0" width="64" height="20"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <!-- activeLabel inside pill -->
                            <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="act-L3-jkl">
                                <rect key="frame" x="4" y="2" width="56" height="16"/>
                                <textFieldCell key="cell" lineBreakMode="clipping" alignment="center" title="ACTIVE" id="act-c-jkl">
                                    <font key="font" metaFont="systemBold" size="10"/>
                                    <color key="textColor" name="WhiteText"/>
                                    <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                                </textFieldCell>
                            </textField>
                        </subviews>
                        <constraints>
                            <constraint firstItem="act-L3-jkl" firstAttribute="leading" secondItem="pill-cv-ghi" secondAttribute="leading" constant="4" id="act-con-lead"/>
                            <constraint firstItem="act-L3-jkl" firstAttribute="trailing" secondItem="pill-cv-ghi" secondAttribute="trailing" constant="-4" id="act-con-trail"/>
                            <constraint firstItem="act-L3-jkl" firstAttribute="centerY" secondItem="pill-cv-ghi" secondAttribute="centerY" id="act-con-cy"/>
                        </constraints>
                    </view>
                    <constraints>
                        <constraint firstAttribute="width" constant="64" id="pill-w"/>
                        <constraint firstAttribute="height" constant="20" id="pill-h"/>
                    </constraints>
                    <color key="fillColor" name="PrimaryGreen"/>
                </box>
                <!-- createdAtLabel: date -->
                <textField horizontalHuggingPriority="251" verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="dat-L4-mno">
                    <rect key="frame" x="88" y="24" width="140" height="17"/>
                    <textFieldCell key="cell" lineBreakMode="clipping" sendsActionOnEndEditing="YES" title="date" id="dat-c-mno">
                        <font key="font" usesAppearanceFont="YES"/>
                        <color key="textColor" name="SecondaryText"/>
                        <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                    </textFieldCell>
                </textField>
                <!-- copyTokenButton -->
                <button translatesAutoresizingMaskIntoConstraints="NO" id="btn-tok-pqr" customClass="CustomButton" customModule="Sphinx" customModuleProvider="target">
                    <rect key="frame" x="340" y="68" width="124" height="32"/>
                    <buttonCell key="cell" type="roundRect" title="COPY TOKEN" id="btn-tok-c-pqr">
                        <font key="font" metaFont="systemBold" size="11"/>
                        <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                    </buttonCell>
                    <connections>
                        <action selector="handleCopyToken:" target="eMx-Yg-Cou" id="btn-tok-act"/>
                    </connections>
                </button>
                <!-- copyJSONButton -->
                <button translatesAutoresizingMaskIntoConstraints="NO" id="btn-jsn-stu" customClass="CustomButton" customModule="Sphinx" customModuleProvider="target">
                    <rect key="frame" x="340" y="28" width="124" height="32"/>
                    <buttonCell key="cell" type="roundRect" title="COPY JSON" id="btn-jsn-c-stu">
                        <font key="font" metaFont="systemBold" size="11"/>
                        <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                    </buttonCell>
                    <connections>
                        <action selector="handleCopyJSON:" target="eMx-Yg-Cou" id="btn-jsn-act"/>
                    </connections>
                </button>
                <!-- separator line -->
                <box boxType="custom" borderType="none" borderWidth="0.0" translatesAutoresizingMaskIntoConstraints="NO" id="sep-B2-vwx">
                    <rect key="frame" x="16" y="4" width="448" height="1"/>
                    <view key="contentView" id="sep-cv-vwx">
                        <rect key="frame" x="0.0" y="0.0" width="448" height="1"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                    </view>
                    <constraints>
                        <constraint firstAttribute="height" constant="1" id="sep-h"/>
                    </constraints>
                    <color key="fillColor" name="SecondaryText"/>
                </box>
            </subviews>
            <constraints>
                <!-- tokenLabel: top, leading, trailing to button area -->
                <constraint firstItem="tok-L1-abc" firstAttribute="top" secondItem="eMx-Yg-Cou" secondAttribute="top" constant="12" id="tok-top"/>
                <constraint firstItem="tok-L1-abc" firstAttribute="leading" secondItem="eMx-Yg-Cou" secondAttribute="leading" constant="16" id="tok-lead"/>
                <constraint firstItem="tok-L1-abc" firstAttribute="trailing" secondItem="btn-tok-pqr" secondAttribute="leading" constant="-8" id="tok-trail"/>
                <constraint firstItem="tok-L1-abc" firstAttribute="height" constant="20" id="tok-h"/>
                <!-- issuerLabel: below tokenLabel -->
                <constraint firstItem="iss-L2-def" firstAttribute="top" secondItem="tok-L1-abc" secondAttribute="bottom" constant="8" id="iss-top"/>
                <constraint firstItem="iss-L2-def" firstAttribute="leading" secondItem="tok-L1-abc" secondAttribute="leading" id="iss-lead"/>
                <constraint firstItem="iss-L2-def" firstAttribute="trailing" secondItem="tok-L1-abc" secondAttribute="trailing" id="iss-trail"/>
                <constraint firstItem="iss-L2-def" firstAttribute="height" constant="17" id="iss-h"/>
                <!-- activePillBox: below issuerLabel, leading -->
                <constraint firstItem="pill-B1-ghi" firstAttribute="top" secondItem="iss-L2-def" secondAttribute="bottom" constant="8" id="pill-top"/>
                <constraint firstItem="pill-B1-ghi" firstAttribute="leading" secondItem="iss-L2-def" secondAttribute="leading" id="pill-lead"/>
                <!-- createdAtLabel: vertically centered with pill, trailing pill -->
                <constraint firstItem="dat-L4-mno" firstAttribute="centerY" secondItem="pill-B1-ghi" secondAttribute="centerY" id="dat-cy"/>
                <constraint firstItem="dat-L4-mno" firstAttribute="leading" secondItem="pill-B1-ghi" secondAttribute="trailing" constant="8" id="dat-lead"/>
                <constraint firstItem="dat-L4-mno" firstAttribute="height" constant="17" id="dat-h"/>
                <!-- copyTokenButton: right column top -->
                <constraint firstItem="btn-tok-pqr" firstAttribute="top" secondItem="eMx-Yg-Cou" secondAttribute="top" constant="16" id="btn-tok-top"/>
                <constraint firstItem="btn-tok-pqr" firstAttribute="trailing" secondItem="eMx-Yg-Cou" secondAttribute="trailing" constant="-16" id="btn-tok-trail"/>
                <constraint firstItem="btn-tok-pqr" firstAttribute="width" constant="124" id="btn-tok-w"/>
                <constraint firstItem="btn-tok-pqr" firstAttribute="height" constant="32" id="btn-tok-h"/>
                <!-- copyJSONButton: below copyTokenButton -->
                <constraint firstItem="btn-jsn-stu" firstAttribute="top" secondItem="btn-tok-pqr" secondAttribute="bottom" constant="8" id="btn-jsn-top"/>
                <constraint firstItem="btn-jsn-stu" firstAttribute="trailing" secondItem="btn-tok-pqr" secondAttribute="trailing" id="btn-jsn-trail"/>
                <constraint firstItem="btn-jsn-stu" firstAttribute="width" secondItem="btn-tok-pqr" secondAttribute="width" id="btn-jsn-w"/>
                <constraint firstItem="btn-jsn-stu" firstAttribute="height" secondItem="btn-tok-pqr" secondAttribute="height" id="btn-jsn-h"/>
                <!-- separator: bottom, full width -->
                <constraint firstItem="sep-B2-vwx" firstAttribute="bottom" secondItem="eMx-Yg-Cou" secondAttribute="bottom" constant="-4" id="sep-bot"/>
                <constraint firstItem="sep-B2-vwx" firstAttribute="leading" secondItem="eMx-Yg-Cou" secondAttribute="leading" constant="16" id="sep-lead"/>
                <constraint firstItem="sep-B2-vwx" firstAttribute="trailing" secondItem="eMx-Yg-Cou" secondAttribute="trailing" constant="-16" id="sep-trail"/>
            </constraints>
            <connections>
                <outlet property="tokenLabel" destination="tok-L1-abc" id="outlet-tok"/>
                <outlet property="issuerLabel" destination="iss-L2-def" id="outlet-iss"/>
                <outlet property="activePillBox" destination="pill-B1-ghi" id="outlet-pill"/>
                <outlet property="activeLabel" destination="act-L3-jkl" id="outlet-act"/>
                <outlet property="createdAtLabel" destination="dat-L4-mno" id="outlet-dat"/>
                <outlet property="copyTokenButton" destination="btn-tok-pqr" id="outlet-btn-tok"/>
                <outlet property="copyJSONButton" destination="btn-jsn-stu" id="outlet-btn-jsn"/>
            </connections>
            <point key="canvasLocation" x="-89" y="39.5"/>
        </tableCellView>
    </objects>
    <resources>
        <namedColor name="BodyInverted">
            <color red="0.082352941176470587" green="0.11764705882352941" blue="0.15294117647058825" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </namedColor>
        <namedColor name="SecondaryText">
            <color red="0.55686274509803924" green="0.58823529411764708" blue="0.61176470588235299" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </namedColor>
        <namedColor name="PrimaryGreen">
            <color red="0.29019607843137254" green="0.8392156862745098" blue="0.49411764705882355" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </namedColor>
        <namedColor name="WhiteText">
            <color red="1" green="1" blue="1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </namedColor>
    </resources>
</document>
